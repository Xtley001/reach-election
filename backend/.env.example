# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://reach:reach_dev_pass@localhost:5432/reach_election
JWT_SECRET=change-me-generate-with-python-secrets-token-hex-32
JWT_SECRET_V1=
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Set to true ONLY if this deployment sits behind a reverse proxy that is
# confirmed to set/overwrite X-Forwarded-For and strip any client-supplied
# value (see audit 3.2). If unset/false, the app uses the raw socket peer
# address instead, which is safer when this can't be verified.
TRUST_PROXY_HEADERS=false

# ── OTP Providers ─────────────────────────────────────────────────────────────
# Recommended production setup:
#   EMAIL_OTP_PROVIDER=brevo   → Brevo transactional email API (no SMTP)
#   SMS_OTP_PROVIDER=termii    → Termii (Nigeria-native, easy registration)
# Set OTP_PROVIDER=console for local dev (prints OTP to terminal).
OTP_PROVIDER=console
EMAIL_OTP_PROVIDER=
SMS_OTP_PROVIDER=

# Brevo — https://app.brevo.com → API Keys (one key covers email + SMS)
BREVO_API_KEY=
BREVO_SENDER=noreply@reach-ng.com

# Termii — https://termii.com → Dashboard → API Key (SMS for Nigerian numbers)
TERMII_API_KEY=
TERMII_SENDER=REACH

ADMIN_BACKUP_EMAIL=
ADMIN_OTP_CC_ENABLED=false

# ── Token Expiry ──────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Redis (optional) ──────────────────────────────────────────────────────────
REDIS_URL=

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
SESSION_INACTIVITY_HOURS=168
